# hermes-webui-plus — Railway env vars (set on the service; secrets never committed).

# --- Web UI ---
HERMES_WEBUI_HOST=0.0.0.0          # bind all interfaces (required in a container)
HERMES_WEBUI_PORT=8787             # web UI port; point the Railway domain at this
HERMES_WEBUI_PASSWORD=             # REQUIRED for remote access — without it anyone who reaches the URL can run the agent
WANTED_UID=1024                    # match the image's hermeswebui user so the mounted volume is readable
WANTED_GID=1024

# --- Model provider (hermes-agent) ---
OPENROUTER_API_KEY=                # hermes-agent auto-detects this for OpenRouter models

# --- Slack bot (hermes gateway, Socket Mode) ---
# Presence of SLACK_BOT_TOKEN (or HERMES_GATEWAY_ENABLED=1) starts the gateway alongside the web UI.
SLACK_BOT_TOKEN=                   # xoxb-...
SLACK_APP_TOKEN=                   # xapp-... (Socket Mode)
SLACK_ALLOWED_USERS=               # comma-separated Slack user IDs allowed to use the bot
# HERMES_GATEWAY_ENABLED=1         # force-start the gateway even without a Slack token

# --- Persistence ---
# Attach a Railway volume at the Hermes home so sessions/config persist:
#   railway volume add -m /home/hermeswebui/.hermes
